export SIGNING_IDENTITY_APP="Developer ID Application: Your Name (TEAMID)"
export SIGNING_IDENTITY_INSTALLER="Developer ID Installer: Your Name (TEAMID)"
export APPLE_ID="your@email.com"
export APPLE_TEAM_ID="TEAMID"

# APPLE_APP_PASSWORD: App-specific password for notarization
# Generate at: https://appleid.apple.com (Security → App-Specific Passwords)
# Option 1: Store in keychain (recommended)
#   xcrun notarytool store-credentials "AC_PASSWORD" \
#     --apple-id "your@email.com" \
#     --team-id "TEAMID" \
#     --password "xxxx-xxxx-xxxx-xxxx"
#   Then use: export APPLE_APP_PASSWORD="@keychain:AC_PASSWORD"
# Option 2: Direct password (less secure)
#   export APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
export APPLE_APP_PASSWORD="@keychain:AC_PASSWORD"

# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. Load and build: source .env